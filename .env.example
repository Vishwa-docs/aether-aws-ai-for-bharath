# ============================================================
# AETHER Elderly Care System — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ============================================================
# NOTE: Never commit .env to version control.
# ============================================================


# ─────────────────────────────────────────────────────────────
#  1. AWS CREDENTIALS & REGION
# ─────────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=123456789012
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# CDK deployment overrides (optional — defaults to above)
CDK_DEFAULT_ACCOUNT=
CDK_DEFAULT_REGION=


# ─────────────────────────────────────────────────────────────
#  2. AWS IOT CORE
# ─────────────────────────────────────────────────────────────
IOT_ENDPOINT=your-iot-endpoint.iot.ap-south-1.amazonaws.com
IOT_THING_GROUP=aether-devices
IOT_CERT_PATH=./certs/device.cert.pem
IOT_KEY_PATH=./certs/device.private.key
IOT_ROOT_CA_PATH=./certs/AmazonRootCA1.pem


# ─────────────────────────────────────────────────────────────
#  3. AWS COGNITO
# ─────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=your-cognito-app-client-id
COGNITO_APP_CLIENT_SECRET=your-cognito-app-client-secret
COGNITO_DOMAIN=aether-auth.auth.ap-south-1.amazoncognito.com
COGNITO_IDENTITY_POOL_ID=ap-south-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────
#  4. DYNAMODB TABLE NAMES
# ─────────────────────────────────────────────────────────────
DYNAMODB_EVENTS_TABLE=aether-events
DYNAMODB_TIMELINE_TABLE=aether-timeline
DYNAMODB_RESIDENTS_TABLE=aether-residents
DYNAMODB_CONSENT_TABLE=aether-consent
DYNAMODB_CLINIC_OPS_TABLE=aether-clinic-ops

# Lambda env var aliases (used inside Lambda handlers)
EVENTS_TABLE=aether-events
TIMELINE_TABLE=aether-timeline
RESIDENTS_TABLE=aether-residents
CONSENT_TABLE=aether-consent
CLINIC_OPS_TABLE=aether-clinic-ops


# ─────────────────────────────────────────────────────────────
#  5. S3 BUCKETS
# ─────────────────────────────────────────────────────────────
S3_EVIDENCE_BUCKET=aether-evidence-ap-south-1-123456789012
S3_MODELS_BUCKET=aether-models-ap-south-1-123456789012
S3_KNOWLEDGE_BUCKET=aether-knowledge-ap-south-1-123456789012
S3_ARCHIVE_BUCKET=aether-archive-ap-south-1-123456789012

# Lambda env var aliases
EVIDENCE_BUCKET=aether-evidence-ap-south-1-123456789012
MODELS_BUCKET=aether-models-ap-south-1-123456789012


# ─────────────────────────────────────────────────────────────
#  6. API GATEWAY
# ─────────────────────────────────────────────────────────────
API_GATEWAY_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/v1
API_GATEWAY_ID=your-api-id
API_GATEWAY_STAGE=v1


# ─────────────────────────────────────────────────────────────
#  7. KINESIS DATA STREAM
# ─────────────────────────────────────────────────────────────
KINESIS_STREAM_NAME=aether-sensor-stream
KINESIS_SHARD_COUNT=1


# ─────────────────────────────────────────────────────────────
#  8. TIMESTREAM
# ─────────────────────────────────────────────────────────────
TIMESTREAM_DATABASE=aether-telemetry
TIMESTREAM_TABLE=sensor-readings
TIMESTREAM_RETENTION_HOURS=24
TIMESTREAM_MAGNETIC_RETENTION_DAYS=365


# ─────────────────────────────────────────────────────────────
#  9. SNS NOTIFICATIONS
# ─────────────────────────────────────────────────────────────
SNS_ALERTS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:aether-alerts
SNS_CAREGIVER_PHONE=+91XXXXXXXXXX
SNS_EMERGENCY_PHONE=+91108

# Lambda env alias
ALERTS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:aether-alerts


# ─────────────────────────────────────────────────────────────
#  10. STEP FUNCTIONS
# ─────────────────────────────────────────────────────────────
FALL_WORKFLOW_ARN=arn:aws:states:ap-south-1:123456789012:stateMachine:aether-fall-detection
MEDICATION_WORKFLOW_ARN=arn:aws:states:ap-south-1:123456789012:stateMachine:aether-medication-adherence
ESCALATION_SFN_ARN=arn:aws:states:ap-south-1:123456789012:stateMachine:aether-fall-detection


# ─────────────────────────────────────────────────────────────
#  11. AWS BEDROCK (GenAI)
# ─────────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_CLAUDE_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_TITAN_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_TITAN_IMAGE_MODEL_ID=amazon.titan-image-generator-v1
BEDROCK_GUARDRAIL_ID=your-guardrail-id
BEDROCK_GUARDRAIL_VERSION=DRAFT
BEDROCK_KNOWLEDGE_BASE_ID=your-knowledge-base-id


# ─────────────────────────────────────────────────────────────
#  12. NVIDIA NGC
# ─────────────────────────────────────────────────────────────
NGC_API_KEY=your-ngc-api-key
NGC_ORG_ID=your-ngc-org-id


# ─────────────────────────────────────────────────────────────
#  13. PICOVOICE / PORCUPINE (Wake Word Detection)
# ─────────────────────────────────────────────────────────────
PORCUPINE_ACCESS_KEY=your-porcupine-access-key
PORCUPINE_KEYWORD_PATH=./edge/models/hey-sentinel.ppn
PORCUPINE_MODEL_PATH=./edge/models/porcupine_params.pv
PORCUPINE_SENSITIVITY=0.7


# ─────────────────────────────────────────────────────────────
#  14. AWS TRANSCRIBE
# ─────────────────────────────────────────────────────────────
TRANSCRIBE_LANGUAGE_CODE=en-IN
TRANSCRIBE_SAMPLE_RATE=16000
TRANSCRIBE_MEDIA_ENCODING=pcm
TRANSCRIBE_VOCABULARY_NAME=aether-medical-vocab


# ─────────────────────────────────────────────────────────────
#  15. AWS POLLY
# ─────────────────────────────────────────────────────────────
POLLY_VOICE_ID=Kajal
POLLY_ENGINE=neural
POLLY_LANGUAGE_CODE=en-IN
POLLY_OUTPUT_FORMAT=mp3
POLLY_SAMPLE_RATE=22050


# ─────────────────────────────────────────────────────────────
#  16. MQTT (Local Broker)
# ─────────────────────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_BROKER_WS_PORT=9001


# ─────────────────────────────────────────────────────────────
#  17. EDGE GATEWAY
# ─────────────────────────────────────────────────────────────
EDGE_DEVICE_ID=edge-gateway-001
EDGE_HOME_ID=home-001
EDGE_OFFLINE_DB_PATH=./edge/data/events.db
EDGE_LOG_LEVEL=INFO


# ─────────────────────────────────────────────────────────────
#  18. SENSOR SIMULATION
# ─────────────────────────────────────────────────────────────
SIMULATOR_MODE=true
SIMULATOR_SPEED=1.0
SIMULATOR_SEED=42


# ─────────────────────────────────────────────────────────────
#  19. DIGITAL TWIN
# ─────────────────────────────────────────────────────────────
DIGITAL_TWIN_HOMES=4
DIGITAL_TWIN_DAYS=90
DIGITAL_TWIN_OUTPUT_DIR=./data/synthetic


# ─────────────────────────────────────────────────────────────
#  20. TWILIO (SMS / Voice Fallback)
# ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX


# ─────────────────────────────────────────────────────────────
#  21. APPLICATION SETTINGS
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=false
POWERTOOLS_SERVICE_NAME=aether

# Feature flags (Lambda handlers)
TRIAGE_ENABLED=true
ESCALATION_ENABLED=true


# ─────────────────────────────────────────────────────────────
#  22. DASHBOARD (Vite — prefixed with VITE_)
# ─────────────────────────────────────────────────────────────
VITE_API_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/v1
VITE_WS_URL=wss://your-ws-api-id.execute-api.ap-south-1.amazonaws.com/v1
VITE_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=your-cognito-app-client-id
VITE_COGNITO_DOMAIN=aether-auth.auth.ap-south-1.amazoncognito.com
VITE_AWS_REGION=ap-south-1
